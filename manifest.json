{\n  "manifest_version": 3,\n  "name": "Google FX Tools Auto Fill",\n  "version": "1.0",\n  "description": "Tự động điền text vào ô input trong Google FX Tools",\n  "permissions": [\n    "activeTab",\n    "scripting",\n    "tabs",\n    "storage",\n    "clipboardRead",\n    "clipboardWrite"\n  ],\n  "host_permissions": [\n    "https://labs.google/*"\n  ],\n  "action": {\n    "default_popup": "popup.html"\n  },\n  "background": {\n    "service_worker": "background.js"\n  },\n  "content_scripts": [\n    {\n      "matches": ["https://labs.google/*"],\n      "js": ["content.js"]\n    }\n  ]\n}